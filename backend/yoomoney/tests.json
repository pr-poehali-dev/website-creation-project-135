{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unknown action returns error",
      "method": "GET",
      "path": "/?action=unknown",
      "expectedStatus": 400,
      "expectedBody": {"error": "Unknown action"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Create without order_id",
      "method": "POST",
      "path": "/?action=create",
      "body": "{}",
      "expectedStatus": 400,
      "expectedBody": {"error": "order_id required"},
      "bodyMatcher": "partial"
    }
  ]
}