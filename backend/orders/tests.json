    {
      "name": "Unknown network",
      "method": "POST",
      "path": "/?action=create",
      "body": {"item_id": 1, "item_name": "Test", "price_usd": 1.0, "quantity": 1, "network": "UNKNOWN"},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    },
    {
      "name": "Get orders without admin token",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 403,
      "bodyMatcher": "partial"
    }
