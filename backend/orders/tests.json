      "path": "/?action=create",
      "body": {
        "item_id": 11,
        "item_name": "Random PACK SAB",
        "price_usd": 0.5,
        "quantity": 1,
        "network": "LTC"
      },
      "expectedStatus": 200,
      "expectedBody": {"address": "ltc1qw6m0527yhuah7n72m7gad9acrdczzufhwcckk0"},
      "bodyMatcher": "partial"
